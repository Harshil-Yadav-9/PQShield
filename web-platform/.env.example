# Postgres connection string. For Neon: dashboard.neon.tech → your project
# → Connect → copy the "Pooled connection" string (works both locally and
# on Vercel — Neon's serverless driver, used in src/lib/prisma.ts, doesn't
# need Vercel's separate Postgres integration).
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Generate with: npx auth secret   (writes AUTH_SECRET below automatically)
# If you generate one by hand instead (e.g. `openssl rand -base64 32`), put
# it in either AUTH_SECRET or NEXTAUTH_SECRET — src/lib/auth.ts reads both.
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
# (add both the localhost and production URL as separate authorized
# redirect URIs in the same OAuth client once you deploy)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gmail SMTP — sends verification emails through your own Gmail account,
# not a third-party email API. Zero cost, forever, no vendor account:
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Google Account → Security → App passwords → create one for "Mail"
#      (search "App passwords" in your account settings if you don't see it
#      directly — it only appears once 2-Step Verification is on).
#   3. Paste the 16-character password below (spaces don't matter).
# Without this set, registration will fail with a clear error rather than
# silently letting unverified accounts through.
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
# Defaults to GMAIL_USER if left blank — only set this if you want the
# "from" address to differ from the account actually sending the mail.
EMAIL_FROM=""

# URL of the deployed pqc_scanner FastAPI service (pqc_scanner/service.py).
# Local dev default matches `uvicorn pqc_scanner.service:app --port 8000`.
# In production this needs to be a container host (Railway/Fly/Render/etc) —
# it can't be a Vercel serverless function (see README's "Architecture").
SCANNER_URL="http://127.0.0.1:8000"
